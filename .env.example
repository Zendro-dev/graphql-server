ALLOW_ORIGIN="*"
OAUTH2_TOKEN_URI="http://zendro-keycloak:8080/auth/realms/zendro/protocol/openid-connect/token"
GRAPHIQL_REDIRECT_URI=""
SPA_REDIRECT_URI=""

# GraphiQL login (zendro-graphiql) - only needed if GRAPHIQL_AUTH_ENABLED="true"
GRAPHIQL_AUTH_ENABLED="false"
GRAPHIQL_FILTER_ENABLED="false"
OAUTH2_GRAPHIQL_CLIENT_ID="zendro_graphiql"
OAUTH2_GRAPHIQL_CLIENT_SECRET=""
# The realm's OIDC issuer, as reachable by browsers - endpoints (authorization/
# token/end-session) are discovered from
# "<OAUTH2_GRAPHIQL_ISSUER_URI>/.well-known/openid-configuration". Must exactly
# match what Keycloak itself reports as its issuer (its KC_HOSTNAME setting).
OAUTH2_GRAPHIQL_ISSUER_URI="http://localhost:8081/auth/realms/zendro"
# Only needed when the URI above isn't reachable from this process - e.g.
# Keycloak in Docker Compose, where the issuer above is the host's published
# port but this server must actually connect via the internal service
# hostname (with KC_HOSTNAME_BACKCHANNEL_DYNAMIC, Keycloak then reports
# token/jwks endpoints matching whichever hostname reached it).
OAUTH2_GRAPHIQL_ISSUER_INTERNAL_URI="http://zendro-keycloak:8081/auth/realms/zendro"
SESSION_SECRET=""
MAIL_SERVICE=""
MAIL_HOST=""
MAIL_ACCOUNT=""
MAIL_PASSWORD=""
ERROR_LOG="compact"
EXPORT_TIME_OUT="3600"
LIMIT_RECORDS="10000"
PORT="3000"
POST_REQUEST_MAX_BODY_SIZE="1mb"
MAX_TIME_OUT="2000"
REQUIRE_SIGN_IN="true"
SALT_ROUNDS="10"
WHITELIST_ROLES=""
DOWN_MIGRATION="false"
MIGRATION_USERNAME=""
MIGRATION_PASSWORD=""