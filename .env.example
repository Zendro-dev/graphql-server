ALLOW_ORIGIN="*"
OAUTH2_TOKEN_URI="http://zendro-keycloak:8080/auth/realms/zendro/protocol/openid-connect/token"
GRAPHIQL_REDIRECT_URI=""
SPA_REDIRECT_URI=""

# GraphiQL login (zendro-graphiql) - only needed if GRAPHIQL_AUTH_ENABLED="true"
GRAPHIQL_AUTH_ENABLED="false"
GRAPHIQL_FILTER_ENABLED="false"
OAUTH2_GRAPHIQL_CLIENT_ID="zendro_graphiql"
OAUTH2_GRAPHIQL_CLIENT_SECRET=""
# The realm's OIDC issuer - endpoints (authorization/token/end-session) are
# discovered from "<OAUTH2_GRAPHIQL_ISSUER_URI>/.well-known/openid-configuration".
OAUTH2_GRAPHIQL_ISSUER_URI="http://zendro-keycloak:8080/auth/realms/zendro"
SESSION_SECRET=""
MAIL_SERVICE=""
MAIL_HOST=""
MAIL_ACCOUNT=""
MAIL_PASSWORD=""
ERROR_LOG="compact"
EXPORT_TIME_OUT="3600"
LIMIT_RECORDS="10000"
PORT="3000"
POST_REQUEST_MAX_BODY_SIZE="1mb"
MAX_TIME_OUT="2000"
REQUIRE_SIGN_IN="true"
SALT_ROUNDS="10"
WHITELIST_ROLES=""
DOWN_MIGRATION="false"
MIGRATION_USERNAME=""
MIGRATION_PASSWORD=""